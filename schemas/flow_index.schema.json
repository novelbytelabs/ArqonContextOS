{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arqon.dev/schemas/flow_index.schema.json",
  "title": "ArqonMonkeyOS Flow Index v0.3",
  "type": "object",
  "required": ["schema_version", "project", "updated_at", "flows"],
  "properties": {
    "schema_version": { "const": "flow_index.v0.3" },
    "project": { "type": "string" },
    "updated_at": { "type": "string" },
    "flows": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["flow_id", "name", "type", "title", "status", "current_gate", "created_at", "updated_at", "source_path"],
        "properties": {
          "flow_id": { "type": "string" },
          "name": { "type": "string" },
          "type": { "enum": ["science_flow", "code_flow", "audit_flow", "governance_flow"] },
          "title": { "type": "string" },
          "status": { "enum": ["active", "blocked", "completed", "archived"] },
          "current_gate": { "enum": ["DRAFT", "PLAN_READY", "DEV_EVIDENCE_READY", "INTEGRITY_GATE_PASSED", "CLAIM_OR_PROMOTION_CANDIDATE", "HUMAN_APPROVED"] },
          "created_at": { "type": "string" },
          "updated_at": { "type": "string" },
          "source_path": { "type": "string" }
        }
      }
    }
  }
}
