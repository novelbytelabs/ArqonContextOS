yarn-debug.log*
yarn-error.log*
.pnp*
.vscode-test/
dist/
vscode-plugin/package-lock.json
vscode-plugin/yarn.lock

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
*.log
site/

# C++ / Rust
target/
*.o
*.a
*.so
*.out

# Editors
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Multimedia and Archives
*.wav
*.mp3
*.tar.gz
*.tar.xz
*.zip
*.vsix
*.raw

# User Added
/temps
.agents/
.codex/
